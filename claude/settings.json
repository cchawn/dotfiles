{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(bundle:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(gem:*)",
      "Bash(gh:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git push:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(grep:*)",
      "Bash(gt bottom:*)",
      "Bash(gt branch:*)",
      "Bash(gt checkout:*)",
      "Bash(gt create:*)",
      "Bash(gt down:*)",
      "Bash(gt log:*)",
      "Bash(gt ls:*)",
      "Bash(gt restack:*)",
      "Bash(gt status:*)",
      "Bash(gt sync:*)",
      "Bash(gt top:*)",
      "Bash(gt up:*)",
      "Bash(acli:*)",
      "Bash(ls:*)",
      "Bash(npm:*)",
      "Bash(nx:*)",
      "Bash(pnpm:*)",
      "Bash(sed:*)",
      "Bash(sentry-cli:*)",
      "Bash(tree:*)",
      "Bash(yarn:*)",
      "Skill(jira-cli)",
      "Skill(sentry-cli)",
      "mcp__datadog__*"
    ]
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "graphite@ws-claude-marketplace": true,
    "ruby-lsp@claude-plugins-official": true,
    "superpowers@ws-claude-marketplace": true,
    "devcontainer-setup@ws-claude-marketplace": true,
    "incident-command@ws-claude-marketplace": true,
    "betting@ws-claude-marketplace": true
  },
  "gitAttribution": false,
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Frog.aiff"
          }
        ]
      }
    ]
  }
}
